# =============================================================================
# DZ News Monitor – environment configuration
# Copy this file to .env and fill in your values.
# For local development overrides, use .env.local (not committed).
# =============================================================================

# --- Flask -------------------------------------------------------------------
FLASK_PORT=5088
FLASK_SECRET_KEY=change-me-to-a-random-secret

# --- Database (MySQL / MariaDB) ----------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dz_news
DB_USER=
DB_PASS=

# --- SerpAPI (Google News search) -------------------------------------------
# Get your key at https://serpapi.com/
SERPAPI_KEY=

# Search parameters (defaults are good for Algeria/French)
SERP_HL=fr
SERP_GL=dz
SERP_NUM=10
SERP_WHEN=7d
SERP_ENGINE=

# --- Translation backend (Arabic → French) ----------------------------------
# Choose one: local | deepl | azure  (default: local)
TRANSLATOR_BACKEND=local

# Local MarianMT service URL (used when TRANSLATOR_BACKEND=local)
TRANSLATOR_URL=https://your-local-translator.example.com

# DeepL API key (used when TRANSLATOR_BACKEND=deepl)
# Get your key at https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Azure Cognitive Translator (used when TRANSLATOR_BACKEND=azure)
# Get your key at https://portal.azure.com
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=westeurope

# --- Extraction --------------------------------------------------------------
EXTRACT_MAX=50
EXTRACT_ONLY_MISSING=true

# --- Preferred domains (optional, overrides sources.json) -------------------
# Comma-separated list of Algerian news domains to prioritize
# PREFERRED_DOMAINS=elmoudjahid.com,aps.dz,tsa-algerie.com

# --- Paths (optional, defaults relative to project root) --------------------
# BUNDLE_DIR=./bundle
# RUNS_DIR=./bundle/runs
# LOG_DIR=./logs
# LATEST_BUNDLE_PATH=./bundle/latest/news_bundle.json

# --- Logging -----------------------------------------------------------------
LOG_FILE=app.log
LOG_LEVEL=INFO
LOG_PREFIX=dznews
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=5

# --- SMTP notifications (optional) ------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_TO=